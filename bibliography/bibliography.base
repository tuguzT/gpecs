filters:
  and:
    - file.folder == "bibliography"
    - file.ext != "base"
formulas:
  Can I use it now?: note["publication-date"] + "5y" > today()
properties:
  file.name:
    displayName: Name
  file.tags:
    displayName: Tags
  note.publication-date:
    displayName: Publication date
  note.source:
    displayName: Source
views:
  - type: table
    name: Maps of Content
    filters:
      and:
        - file.tags.containsAny("paper", "conf", "book", "web")
    order:
      - file.name
      - file.tags
      - publication-date
      - formula.Can I use it now?
    sort:
      - property: formula.Can I use it now?
        direction: DESC
      - property: publication-date
        direction: DESC
